{
  "name": "picrophone",
  "version": "0.10.3",
  "description": "On-device dictation + text-to-speech bridge for the pi coding agent (macOS; Windows coming soon).",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "files": [
    "extension",
    "assets",
    "README.md"
  ],
  "optionalDependencies": {
    "picrophone-darwin": "0.10.3",
    "picrophone-win32": "0.10.3"
  },
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "build:swift": "swift build --package-path native -c release --arch arm64 && swift build --package-path native -c release --arch x86_64",
    "build": "npm run gen-version && npm run build:swift && npm run install-bin && npm run build:app",
    "install-bin": "bash scripts/install-bin.sh",
    "build:app": "bash scripts/build-app.sh",
    "build:cues": "node scripts/bake-cues.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf native/.build packages/picrophone-darwin/bin/picrophone packages/picrophone-darwin/bin/Picrophone.app native/Sources/picrophone/Version.swift",
    "publish:all": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "latest",
    "@types/node": "^22",
    "typebox": "^1.3.3",
    "typescript": "^5"
  }
}
